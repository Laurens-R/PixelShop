{
  "name": "pixelshop",
  "version": "0.1.0",
  "description": "A pixel art and image editing desktop application",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:wasm": "emcmake cmake -S wasm -B wasm/build -DCMAKE_BUILD_TYPE=Release && cmake --build wasm/build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --project tsconfig.node.json --noEmit",
    "typecheck:web": "tsc --project tsconfig.web.json --noEmit",
    "typecheck": "npm run typecheck:node && npm run typecheck:web"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "electron": "^36.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "@webgpu/types": "^0.1.69",
    "electron-vite": "^3.1.0",
    "sass": "^1.86.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0"
  }
}
